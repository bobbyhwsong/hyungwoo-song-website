---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { notes } from '../../../data/notes';
export function getStaticPaths() { return notes.map((note) => ({ params: { slug: note.slug }, props: { note } })); }
const { note } = Astro.props;
const target = `/ko/thoughts/${note.slug}/`;
---
<BaseLayout title={`${note.title.ko} — 생각`} lang="ko"><section class="page-hero"><div class="wrap"><div class="eyebrow">Moved</div><h1 class="page-title">이 글은 생각으로 옮겼습니다.</h1><div class="cta-row"><a class="btn" href={target}>글 열기</a></div></div></section><script is:inline define:vars={{ target }}>window.location.replace(target);</script></BaseLayout>