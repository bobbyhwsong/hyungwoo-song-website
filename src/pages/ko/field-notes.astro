---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { notes } from '../../data/notes';
---
<BaseLayout title="필드노트 — Hyungwoo Song" lang="ko"><section class="page-hero editorial"><div class="wrap"><div class="eyebrow">Field Notes</div><h1 class="page-title">생각을 짧게 남기는 곳.</h1><p class="lead">완성된 주장보다, 계속 붙잡고 싶은 질문을 모아둡니다.</p></div></section><section class="section tight"><div class="wrap note-index">{notes.map((note, i)=><a class={`note-row tone-${i % 4}`} href={`/ko/field-notes/${note.slug}/`}><div class="note-number">{String(i+1).padStart(2,'0')}</div><div><span class="stamp">{note.tags.slice(0,2).join(' · ')}</span><h2>{note.title.ko}</h2><p>{note.excerpt.ko}</p></div><span class="arrow">→</span></a>)}</div></section></BaseLayout>