---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { notes } from '../../data/notes';
---
<BaseLayout title="필드노트 — Hyungwoo Song" lang="ko"><section class="page-hero"><div class="wrap"><div class="eyebrow">필드노트</div><h1 class="page-title">계속 생각하고 싶은 것들을 남겨두는 곳입니다.</h1><p class="lead">필드노트는 완성된 논문이 아니라, 내가 기록하고 싶은 생각, 이미지, 장면, 질문을 쌓아두는 공간입니다.</p></div></section><section class="section"><div class="wrap postcard-grid">{notes.map((note, i)=><a class="postcard note-link featured-note" style={`--r:${i % 2 ? '1.4deg' : '-1.4deg'}`} href={`/ko/field-notes/${note.slug}/`}>{note.image && <img src={note.image} alt="필드노트 이미지" />}<span class="stamp">{note.date}</span><h3>{note.title.ko}</h3><p>{note.excerpt.ko}</p><strong>전문 읽기 →</strong></a>)}</div></section></BaseLayout>