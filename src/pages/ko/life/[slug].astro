---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { lifePosts } from '../../../data/life';
export function getStaticPaths() { return lifePosts.map((post) => ({ params: { slug: post.slug }, props: { post } })); }
const { post } = Astro.props;
const target = `/ko/thoughts/${post.slug}/`;
---
<BaseLayout title={`${post.title.ko} — 생각`} lang="ko"><section class="page-hero"><div class="wrap"><div class="eyebrow">Moved</div><h1 class="page-title">이 글은 생각으로 옮겼습니다.</h1><div class="cta-row"><a class="btn" href={target}>글 열기</a></div></div></section><script is:inline define:vars={{ target }}>window.location.replace(target);</script></BaseLayout>