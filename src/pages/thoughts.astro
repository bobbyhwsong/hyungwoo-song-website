---
import BaseLayout from '../layouts/BaseLayout.astro';
import { thoughts } from '../data/thoughts';
---
<BaseLayout title="Thoughts — Hyungwoo Song" lang="en"><section class="page-hero thoughts-hero"><div class="wrap"><div class="eyebrow">Thoughts</div><h1 class="page-title">A free space for thinking in public.</h1><p class="lead">Research questions, field notes, films, books, scenes, and fragments that shape how I pay attention.</p></div></section><section class="section tight"><div class="wrap thought-index">{thoughts.map((thought, i)=><a class={`thought-row tone-${i % 4}`} href={`/thoughts/${thought.slug}/`}><div class="note-number">{String(i+1).padStart(2,'0')}</div><div><span class="stamp">{thought.kind.en} · {thought.tags.slice(0,2).join(' · ')}</span><h2>{thought.title.en}</h2><p>{thought.excerpt.en}</p></div><span class="arrow">→</span></a>)}</div></section></BaseLayout>