      <section class="final">
        <div class="kicker">Thank you</div>
        <h2>그날 뵙겠습니다.</h2>
        <p style="color:var(--muted);margin:0">송형우 그리고 강혜진</p>
      </section>

      <div class="floating-nav" aria-label="청첩장 메뉴">
        <nav>
          <a href="#invite">초대</a>
          <a href="#when">일시</a>
          <a href="#gallery">사진</a>
          <a href="#map">장소</a>
        </nav>
      </div>
    </div>

    <div class="photo-modal" id="photoModal" aria-hidden="true">
      <button class="modal-close" type="button" aria-label="닫기">×</button>
      <button class="modal-nav prev" type="button" aria-label="이전 사진">‹</button>
      <figure class="modal-photo-shell">
        <div class="modal-photo protected-photo" id="modalPhoto" role="img" aria-label="선택한 사진 확대 보기"><span id="modalPhotoLabel">PHOTO 01</span></div>
        <figcaption><span id="modalCounter">1 / 20</span> · 한 번 더 누르면 모자이크 보기</figcaption>
      </figure>
      <button class="modal-nav next" type="button" aria-label="다음 사진">›</button>
    </div>

    <script>
      const cover = document.getElementById('cover');
      const openInvitation = () => {
        if (!cover || cover.classList.contains('opened')) return;
        cover.classList.add('opened');
        window.setTimeout(() => cover.classList.add('zooming'), 980);
        window.setTimeout(() => {
          cover.classList.add('done');
          document.body.classList.remove('opening');
          document.body.classList.add('body-ready');
          window.scrollTo({ top: 0, behavior: 'instant' });
        }, 1720);
      };
      document.getElementById('openInvitation')?.addEventListener('click', openInvitation);
      cover?.addEventListener('click', (event) => { if (event.target === cover) openInvitation(); });
      document.addEventListener('contextmenu', (event) => { if (event.target.closest?.('.protected-photo,.photo-card,.photo-modal,.collage-frame')) event.preventDefault(); });
      document.addEventListener('dragstart', (event) => { if (event.target.closest?.('.protected-photo,.photo-card,.photo-modal,.collage-frame')) event.preventDefault(); });
      const photoModal = document.getElementById('photoModal');
      const modalPhoto = document.getElementById('modalPhoto');
      const modalPhotoLabel = document.getElementById('modalPhotoLabel');
      const modalCounter = document.getElementById('modalCounter');
      const totalPhotos = 20;
      let currentPhoto = 0;
      const renderPhoto = () => {
        if (!modalPhoto || !modalPhotoLabel || !modalCounter) return;
        modalPhoto.classList.remove('mosaic');
        modalPhotoLabel.textContent = `PHOTO ${String(currentPhoto + 1).padStart(2, '0')}`;
        modalCounter.textContent = `${currentPhoto + 1} / ${totalPhotos}`;
      };
      const openPhoto = (index = 0) => {
        currentPhoto = (index + totalPhotos) % totalPhotos;
        renderPhoto();
        photoModal?.classList.add('show');
        photoModal?.setAttribute('aria-hidden','false');
      };
      const closePhoto = () => { photoModal?.classList.remove('show'); photoModal?.setAttribute('aria-hidden','true'); };
      const movePhoto = (delta) => { currentPhoto = (currentPhoto + delta + totalPhotos) % totalPhotos; renderPhoto(); };
      document.querySelectorAll('[data-photo-index]').forEach((tile) => {
        tile.addEventListener('click', () => openPhoto(Number(tile.dataset.photoIndex || 0)));
        tile.addEventListener('keydown', (event) => { if (event.key === 'Enter' || event.key === ' ') { event.preventDefault(); openPhoto(Number(tile.dataset.photoIndex || 0)); } });
      });
      document.querySelector('.postcard-photo')?.addEventListener('click', () => openPhoto(0));
      modalPhoto?.addEventListener('click', (event) => { event.stopPropagation(); modalPhoto.classList.toggle('mosaic'); });
      document.querySelector('.modal-nav.prev')?.addEventListener('click', (event) => { event.stopPropagation(); movePhoto(-1); });
      document.querySelector('.modal-nav.next')?.addEventListener('click', (event) => { event.stopPropagation(); movePhoto(1); });
      photoModal?.addEventListener('click', (event) => { if (event.target === photoModal) closePhoto(); });
      document.querySelector('.modal-close')?.addEventListener('click', closePhoto);
      document.addEventListener('keydown', (event) => {
        if (!photoModal?.classList.contains('show')) return;
        if (event.key === 'Escape') closePhoto();
        if (event.key === 'ArrowLeft') movePhoto(-1);
        if (event.key === 'ArrowRight') movePhoto(1);
      });
      const target = new Date('2026-10-24T12:00:00+09:00').getTime();
      const ids = ['d','h','m','s'].map((id) => document.getElementById(id));
      function tick(){
        const diff = Math.max(0, target - Date.now());
        const d = Math.floor(diff / 86400000);
        const h = Math.floor((diff % 86400000) / 3600000);
        const m = Math.floor((diff % 3600000) / 60000);
        const s = Math.floor((diff % 60000) / 1000);
        [d,h,m,s].forEach((v,i)=>{ if(ids[i]) ids[i].textContent = String(v).padStart(i ? 2 : 1,'0'); });
      }
      tick(); setInterval(tick, 1000);
      document.querySelectorAll('.copy').forEach((btn)=>{
        btn.addEventListener('click', async ()=>{
          try { await navigator.clipboard.writeText(btn.dataset.copy || ''); btn.textContent='완료'; setTimeout(()=>btn.textContent='복사',1200); }
          catch { btn.textContent='복사 실패'; setTimeout(()=>btn.textContent='복사',1200); }
        });
      });
    </script>
  </body>
</html>
