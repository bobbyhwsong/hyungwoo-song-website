---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { notes } from '../../data/notes';
export function getStaticPaths() { return notes.map((note) => ({ params: { slug: note.slug }, props: { note } })); }
const { note } = Astro.props;
const target = `/thoughts/${note.slug}/`;
---
<BaseLayout title={`${note.title.en} — Thoughts`} lang="en"><section class="page-hero"><div class="wrap"><div class="eyebrow">Moved</div><h1 class="page-title">This note moved to Thoughts.</h1><div class="cta-row"><a class="btn" href={target}>Open note</a></div></div></section><script is:inline define:vars={{ target }}>window.location.replace(target);</script></BaseLayout>