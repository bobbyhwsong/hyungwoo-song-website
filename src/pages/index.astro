---
import BaseLayout from '../layouts/BaseLayout.astro';
import PublicationList from '../components/PublicationList.astro';
import { publications } from '../data/publications';
import { profile } from '../data/profile';
---
<BaseLayout title="Hyungwoo Song — HCI Researcher" lang="en" description="Hyungwoo Song is an HCI researcher studying human-centered AI, accessibility, education, healthcare, and everyday decision-making.">
  <section class="hero hero-minimal"><div class="wrap hero-grid"><div><div class="eyebrow">HCI · Human-Centered AI · Accessibility</div><h1>Designing more careful relationships between people and AI.</h1><p class="lead">I study how AI changes human judgment, voice, access, learning, and care.</p><div class="hero-tags"><span>Human-Centered AI</span><span>Accessibility</span><span>Education</span><span>Healthcare</span></div><div class="cta-row"><a class="btn" href="/publications/">Selected work</a><a class="btn secondary" href={profile.cv}>CV</a></div></div><aside class="hero-side compact"><figure class="portrait-card"><img src={profile.portrait} alt="Portrait of Hyungwoo Song"><figcaption class="portrait-caption">Hyungwoo Song · SNU</figcaption></figure></aside></div></section>
  <section class="section tight"><div class="wrap"><div class="section-kicker">Site map</div><div class="hub-grid"><a class="portal-card research" href="/research/"><span>01</span><h2>Research</h2><p>Research questions across AI, accessibility, education, and healthcare.</p></a><a class="portal-card publications" href="/publications/"><span>02</span><h2>Publications</h2><p>Selected work including MediBridge, EmoBridge, and SIGIR papers.</p></a><a class="portal-card notes" href="/field-notes/"><span>03</span><h2>Field Notes</h2><p>Shorter thinking on relational equality, Bourdieu, and legitimate voice.</p></a><a class="portal-card life" href="/life/"><span>04</span><h2>Life</h2><p>Films, books, narrative, and the things outside research that shape attention.</p></a></div></div></section>
  <section class="section"><div class="wrap split-section"><div><div class="section-kicker">Selected work</div><h2>Representative papers</h2><p class="section-copy">The homepage stays light; the full publication list lives on the publications page.</p><a class="pill dark" href="/publications/">All publications →</a></div><PublicationList publications={publications} selected={true} /></div></section>
</BaseLayout>
