---
import BaseLayout from '../layouts/BaseLayout.astro';
import PublicationList from '../components/PublicationList.astro';
import { publications } from '../data/publications';
import { profile } from '../data/profile';
---
<BaseLayout title="Hyungwoo Song — HCI Researcher" lang="en" description="Hyungwoo Song studies human-centered AI and accessibility for more humane ways of living with technology.">
  <section class="hero hero-minimal"><div class="wrap hero-grid"><div><div class="eyebrow">HCI · Human-Centered AI · Accessibility</div><h1>Designing AI so people can remain fully human.</h1><p class="lead">I am a Ph.D. student in Intelligence and Information at Seoul National University, studying how AI reshapes human judgment, voice, learning, accessibility, and care.</p><p class="sublead">My work is less about smarter automation for its own sake, and more about technologies that help people keep agency, dignity, context, and relationships intact.</p><div class="hero-tags"><span>Human agency</span><span>Accessibility</span><span>Learning</span><span>Care</span></div><div class="cta-row"><a class="btn" href="/research/">Research direction</a><a class="btn secondary" href="/publications/">Publications</a><a class="btn secondary" href={profile.cv}>CV</a></div></div><aside class="hero-side compact"><figure class="portrait-card"><img src={profile.portrait} alt="Portrait of Hyungwoo Song"><figcaption class="portrait-caption">Hyungwoo Song · Seoul National University</figcaption></figure></aside></div></section>
  <section class="section tight"><div class="wrap statement-panel"><p>The question I keep returning to is simple.</p><h2>Can technology help people become not just more efficient users, but more fully themselves?</h2></div></section>
  <section class="section tight"><div class="wrap"><div class="section-kicker">Start here</div><div class="hub-grid"><a class="portal-card research" href="/research/"><span>01</span><h2>Research</h2><p>My Ph.D. direction around agency, access, learning, and care.</p></a><a class="portal-card publications" href="/publications/"><span>02</span><h2>Publications</h2><p>Research output including MediBridge, EmoBridge, and SIGIR papers.</p></a><a class="portal-card notes" href="/thoughts/"><span>03</span><h2>Thoughts</h2><p>A free space for research questions, films, books, scenes, and fragments.</p></a><a class="portal-card life" href="/about/"><span>04</span><h2>About</h2><p>A more personal introduction to how I think and work.</p></a></div></div></section>
  <section class="section"><div class="wrap split-section"><div><div class="section-kicker">Selected work</div><h2>Representative papers</h2><p class="section-copy">Work across accessibility, healthcare, information access, and human-centered AI.</p><a class="pill dark" href="/publications/">All publications →</a></div><PublicationList publications={publications} selected={true} /></div></section>
</BaseLayout>
