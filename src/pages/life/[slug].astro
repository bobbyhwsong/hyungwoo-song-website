---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { lifePosts } from '../../data/life';
export function getStaticPaths() { return lifePosts.map((post) => ({ params: { slug: post.slug }, props: { post } })); }
const { post } = Astro.props;
const target = `/thoughts/${post.slug}/`;
---
<BaseLayout title={`${post.title.en} — Thoughts`} lang="en"><section class="page-hero"><div class="wrap"><div class="eyebrow">Moved</div><h1 class="page-title">This note moved to Thoughts.</h1><div class="cta-row"><a class="btn" href={target}>Open note</a></div></div></section><script is:inline define:vars={{ target }}>window.location.replace(target);</script></BaseLayout>