---
import { profile, ui, type Lang } from '../data/profile';
const { title, description = '', lang = 'en' } = Astro.props as { title: string; description?: string; lang?: Lang };
const t = ui[lang];
const prefix = t.langPrefix;
const link = (path: string) => `${prefix}${path}` || '/';
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <div class="site-bg"></div><div class="grain"></div>
    <header class="nav"><div class="wrap nav-inner"><a class="brand" href={link('/')} aria-label={lang === 'ko' ? '송형우 홈페이지' : 'Hyungwoo Song home'}><img class="brand-logo" src="/assets/logo-mark.svg" alt="" width="28" height="28" aria-hidden="true" /><span>{profile.name}</span></a><nav class="nav-links"><a href={link('/research/')}>{t.nav.research}</a><a href={link('/publications/')}>{t.nav.publications}</a><a href={link('/thoughts/')}>{t.nav.notes}</a><a href={link('/about/')}>{t.nav.about}</a><a href={link('/cv/')}>{t.nav.cv}</a><a class="lang-switch" href={t.otherLangHref}>{t.nav.otherLang}</a></nav></div></header>
    <main><slot /></main>
    <footer class="footer"><div class="wrap footer-inner"><div>{lang === 'ko' ? '한글/영문으로 함께 관리되는 개인 웹사이트.' : 'Built as a bilingual living field notebook.'}</div><div class="nav-links"><a href={`mailto:${profile.email}`}>Email</a><a href={profile.cv}>CV</a><a href={profile.scholar} target="_blank">Scholar</a><a href={profile.orcid} target="_blank">ORCID</a><a href={profile.linkedin} target="_blank">LinkedIn</a><a href={profile.github} target="_blank">GitHub</a></div></div></footer>
  </body>
</html>
